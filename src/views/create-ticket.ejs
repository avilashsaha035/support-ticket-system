<!DOCTYPE html>
<html lang="en">
<head>
    <title>Create Ticket</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

    <!-- Header -->
    <header class="site-header px-4 px-md-5 py-3 d-flex align-items-center justify-content-between">
        <div class="d-flex align-items-center gap-3">
            <div class="brand-icon">
                <svg width="18" height="18" fill="white" viewBox="0 0 24 24"><path d="M9 3H5a2 2 0 00-2 2v4a2 2 0 002 2h4a2 2 0 002-2V5a2 2 0 00-2-2zm0 12H5a2 2 0 00-2 2v4a2 2 0 002 2h4a2 2 0 002-2v-4a2 2 0 00-2-2zm10-12h-4a2 2 0 00-2 2v4a2 2 0 002 2h4a2 2 0 002-2V5a2 2 0 00-2-2zm0 12h-4a2 2 0 00-2 2v4a2 2 0 002 2h4a2 2 0 002-2v-4a2 2 0 00-2-2z"/></svg>
            </div>
            <div>
                <div class="fw-bold" style="font-family:'Syne',sans-serif; font-size:1rem; line-height:1;">Support Portal</div>
                <div style="font-size:.7rem; color:var(--muted); text-transform:uppercase; letter-spacing:.08em;">New Ticket</div>
            </div>
        </div>
        <form action="/logout" method="POST">
            <button class="btn btn-outline-ghost px-3 py-2 d-flex align-items-center gap-2">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4M16 17l5-5-5-5M21 12H9"/></svg>
                Logout
            </button>
        </form>
    </header>

    <!-- Main -->
    <main class="container py-5" style="max-width:640px; position:relative; z-index:1;">

        <!-- Page Title -->
        <div class="mb-4" style="animation: fadeUp .3s ease both;">
            <a href="/dashboard" class="btn btn-back d-inline-flex align-items-center gap-2 mb-3 text-decoration-none">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
                Back
            </a>
            <h2 class="fw-bold mb-1" style="font-family:'Syne',sans-serif; font-size:1.4rem; letter-spacing:-.02em;">Create New Ticket</h2>
            <p style="color:var(--muted); font-size:.875rem;">Describe your issue and we'll get back to you soon.</p>
        </div>

        <div class="form-card p-4 p-sm-5">
            <form action="/create-ticket" method="POST" enctype="multipart/form-data">
                <div class="mb-4">
                    <label class="form-label">Ticket Title</label>
                    <input type="text" name="title" class="form-control" placeholder="e.g. Login page not loading" required>
                </div>
                <div class="mb-4">
                    <label class="form-label">Description</label>
                    <textarea name="description" class="form-control" placeholder="Describe your issue in detail..." required></textarea>
                </div>
                <div class="mb-4">
                    <label class="form-label">Screenshot (optional)</label>
                    <input type="file" name="file" class="form-control file-drop">
                </div>
                <div class="d-flex gap-3">
                    <button type="submit" class="btn btn-accent text-white">Submit Ticket</button>
                    <a href="/dashboard" class="btn btn-back">Cancel</a>
                </div>
            </form>
        </div>

    </main>
</body>
</html>
