<!DOCTYPE html>
<html lang="en">
<head>
    <title>Login</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="d-flex align-items-center justify-content-center" style="min-height:100vh;">
    <div class="w-100 px-3" style="max-width:440px; position:relative; z-index:1;">

        <div class="text-center mb-4">
            <div class="brand-icon mb-3">
                <svg width="20" height="20" fill="white" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 14H9V8h2v8zm4 0h-2V8h2v8z"/></svg>
            </div>
            <h1 class="fw-bold mb-1" style="font-family:'Syne',sans-serif; font-size:1.5rem; letter-spacing:-.02em;">Welcome back</h1>
            <p style="color:var(--muted); font-size:.875rem;">Sign in to your support account</p>
        </div>

        <div class="auth-card p-4 p-sm-5">
            <form action="/login" method="POST">
                <div class="mb-3">
                    <label class="form-label">Email Address</label>
                    <input type="email" name="email" class="form-control" placeholder="you@example.com" required>
                </div>
                <div class="mb-4">
                    <label class="form-label">Password</label>
                    <input type="password" name="password" class="form-control" placeholder="••••••••" required>
                </div>
                <button class="btn btn-auth btn-primary w-100 text-white">Sign In</button>
            </form>
        </div>

        <p class="text-center mt-4" style="color:var(--muted); font-size:.875rem;">
            Don't have an account? <a href="/register" style="color:var(--accent); text-decoration:none; font-weight:500;">Register</a>
        </p>
    </div>
</body>
</html>
