<!DOCTYPE html>
<html lang="en">
<head>
    <title>Support Ticket System</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body class="glow-tr">

    <!-- ── Navbar ── -->
    <nav class="site-header px-4 px-md-5 py-3 d-flex align-items-center justify-content-between">
        <div class="d-flex align-items-center gap-3">
            <div class="brand-icon">
                <svg width="18" height="18" fill="white" viewBox="0 0 24 24"><path d="M9 3H5a2 2 0 00-2 2v4a2 2 0 002 2h4a2 2 0 002-2V5a2 2 0 00-2-2zm0 12H5a2 2 0 00-2 2v4a2 2 0 002 2h4a2 2 0 002-2v-4a2 2 0 00-2-2zm10-12h-4a2 2 0 00-2 2v4a2 2 0 002 2h4a2 2 0 002-2V5a2 2 0 00-2-2zm0 12h-4a2 2 0 00-2 2v4a2 2 0 002 2h4a2 2 0 002-2v-4a2 2 0 00-2-2z"/></svg>
            </div>
            <span class="fw-bold" style="font-family:'Syne',sans-serif; font-size:1rem; letter-spacing:-.01em;">SupportDesk</span>
        </div>
        <div class="d-flex align-items-center gap-2">
            <a href="/login" class="btn-hero-secondary py-2 px-3" style="font-size:.85rem;">Sign In</a>
            <a href="/register" class="btn-hero-primary py-2 px-3" style="font-size:.85rem;">Get Started</a>
        </div>
    </nav>

    <!-- ── Main ── -->
    <main style="position:relative; z-index:1;">

        <!-- Hero -->
        <section class="container py-5">
            <div class="row align-items-center g-5 py-3">

                <!-- Left: Text -->
                <div class="col-lg-6">
                    <!-- Social proof pill -->
                    <div class="hero-badge mb-4">
                        <span></span> Trusted by 1,200+ teams worldwide
                    </div>

                    <h1 class="hero-title mb-3">
                        Stop losing<br>
                        track of your<br>
                        <span class="highlight">customer issues.</span>
                    </h1>

                    <p class="hero-sub mb-4">
                        SupportDesk turns every complaint, bug report, and request into a trackable ticket — so nothing slips through the cracks and your customers always feel heard.
                    </p>

                    <!-- Micro trust signals -->
                    <div class="hero-trust mb-5">
                        <div class="hero-trust-item">
                            <svg width="14" height="14" fill="none" stroke="var(--green)" stroke-width="2.5" stroke-linecap="round" viewBox="0 0 24 24"><path d="M20 6L9 17l-5-5"/></svg>
                            Free to get started — no credit card
                        </div>
                        <div class="hero-trust-item">
                            <svg width="14" height="14" fill="none" stroke="var(--green)" stroke-width="2.5" stroke-linecap="round" viewBox="0 0 24 24"><path d="M20 6L9 17l-5-5"/></svg>
                            Set up in under 2 minutes
                        </div>
                        <div class="hero-trust-item">
                            <svg width="14" height="14" fill="none" stroke="var(--green)" stroke-width="2.5" stroke-linecap="round" viewBox="0 0 24 24"><path d="M20 6L9 17l-5-5"/></svg>
                            Real-time status updates for customers
                        </div>
                    </div>

                    <div class="hero-actions d-flex flex-wrap gap-3 align-items-center">
                        <a href="/register" class="btn-hero-primary">Start for Free →</a>
                        <a href="/login" class="btn-hero-secondary">Sign In</a>
                    </div>

                    <!-- Avatar social proof -->
                    <div class="hero-avatars mt-4">
                        <div class="avatar-stack">
                            <div class="hero-avatar" style="background:#5b6ef5;">A</div>
                            <div class="hero-avatar" style="background:#38c8e8;">K</div>
                            <div class="hero-avatar" style="background:#22c98a;">S</div>
                            <div class="hero-avatar" style="background:#f5a623;">U</div>
                        </div>
                        <span style="font-size:.8rem; color:var(--muted);">
                            Join <strong style="color:var(--text);">1,200+</strong> happy teams already using SupportDesk
                        </span>
                    </div>
                </div>

                <!-- Right: Mockup -->
                <div class="col-lg-6 d-none d-lg-flex justify-content-center" style="position:relative;">
                    <div class="glow-circle"></div>
                    <div class="w-100" style="max-width:390px; position:relative; z-index:1;">

                        <!-- Notification toast (top) -->
                        <div class="mockup-toast mb-3 d-flex align-items-center gap-3">
                            <div style="width:32px;height:32px;border-radius:10px;background:rgba(34,201,138,.15);display:flex;align-items:center;justify-content:center;font-size:.9rem;flex-shrink:0;">✅</div>
                            <div>
                                <div style="font-size:.78rem;font-weight:600;">Ticket #1041 resolved!</div>
                                <div style="font-size:.72rem;color:var(--muted);">Your issue has been closed · just now</div>
                            </div>
                        </div>

                        <!-- Main ticket card -->
                        <div class="mockup-card mb-3">
                            <div class="d-flex align-items-center justify-content-between mb-3">
                                <div class="d-flex align-items-center gap-2">
                                    <div style="width:28px;height:28px;border-radius:8px;background:rgba(91,110,245,.2);display:flex;align-items:center;justify-content:center;font-size:.75rem;">🎫</div>
                                    <span class="fw-bold" style="font-family:'Syne',sans-serif;font-size:.85rem;">Ticket #1042</span>
                                </div>
                                <span class="status-badge badge-progress">In Progress</span>
                            </div>
                            <p class="mb-3" style="font-size:.82rem;color:var(--muted);">Payment gateway failing on checkout page — urgent</p>
                            <div class="mockup-progress-track">
                                <div class="mockup-progress-fill"></div>
                            </div>
                            <div class="d-flex justify-content-between mt-2">
                                <span style="font-size:.72rem;color:var(--muted);">Progress</span>
                                <span style="font-size:.72rem;color:var(--accent);font-weight:600;">65%</span>
                            </div>
                        </div>

                        <!-- Two mini stat cards -->
                        <div class="row g-3">
                            <div class="col-6">
                                <div class="mockup-mini-card">
                                    <div class="mb-1" style="font-size:1.3rem;">⚡</div>
                                    <div class="stat-value" style="color:var(--cyan);">1.8h</div>
                                    <div class="stat-label">Avg. Resolution</div>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="mockup-mini-card">
                                    <div class="mb-1" style="font-size:1.3rem;">😊</div>
                                    <div class="stat-value" style="color:var(--green);">99%</div>
                                    <div class="stat-label">Satisfaction</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- How it works -->
        <section class="container pb-5">
            <div class="text-center mb-5">
                <div class="hero-badge mb-3"><span></span> Simple Process</div>
                <h2 class="fw-bold" style="font-family:'Syne',sans-serif;font-size:1.9rem;letter-spacing:-.02em;">Up and running in 3 steps</h2>
            </div>
            <div class="row g-4 text-center">
                <div class="col-md-4">
                    <div class="howit-card">
                        <div class="howit-step">01</div>
                        <div class="howit-icon">📝</div>
                        <h6 class="fw-bold mb-2" style="font-family:'Syne',sans-serif;">Create an account</h6>
                        <p style="color:var(--muted);font-size:.85rem;line-height:1.65;margin:0;">Sign up free in 30 seconds. No credit card, no setup fees, no contracts.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="howit-card howit-card-active">
                        <div class="howit-step">02</div>
                        <div class="howit-icon">🎫</div>
                        <h6 class="fw-bold mb-2" style="font-family:'Syne',sans-serif;">Submit a ticket</h6>
                        <p style="color:var(--muted);font-size:.85rem;line-height:1.65;margin:0;">Describe your issue, attach a screenshot, and submit — it takes under a minute.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="howit-card">
                        <div class="howit-step">03</div>
                        <div class="howit-icon">🚀</div>
                        <h6 class="fw-bold mb-2" style="font-family:'Syne',sans-serif;">Track & get resolved</h6>
                        <p style="color:var(--muted);font-size:.85rem;line-height:1.65;margin:0;">Watch your ticket status update live as the team works on it and closes it out.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Stats Strip -->
        <section class="container pb-5">
            <div class="stats-strip p-4 d-flex flex-wrap justify-content-around gap-3 text-center">
                <div>
                    <div class="stat-value">500+</div>
                    <div class="stat-label">Tickets Resolved</div>
                </div>
                <div class="stat-divider d-none d-md-block"></div>
                <div>
                    <div class="stat-value">&lt; 2h</div>
                    <div class="stat-label">Avg Response Time</div>
                </div>
                <div class="stat-divider d-none d-md-block"></div>
                <div>
                    <div class="stat-value">99%</div>
                    <div class="stat-label">Satisfaction Rate</div>
                </div>
                <div class="stat-divider d-none d-md-block"></div>
                <div>
                    <div class="stat-value">24/7</div>
                    <div class="stat-label">Always Available</div>
                </div>
            </div>
        </section>

        <!-- Features -->
        <section class="container pb-5">
            <div class="text-center mb-5" style="animation: fadeUp .4s ease both;">
                <div class="hero-badge mb-3">Features</div>
                <h2 class="fw-bold" style="font-family:'Syne',sans-serif;font-size:1.9rem;letter-spacing:-.02em;">Everything you need</h2>
                <p class="mx-auto mt-2" style="color:var(--muted);font-size:.95rem;max-width:420px;">Simple, powerful tools to handle support — without the bloat.</p>
            </div>
            <div class="row g-4">
                <div class="col-md-4">
                    <div class="feature-card d1 h-100">
                        <div class="feature-icon" style="background:rgba(91,110,245,.12);">🎫</div>
                        <h5 class="fw-bold mb-2" style="font-family:'Syne',sans-serif;font-size:1rem;">Instant Tickets</h5>
                        <p class="mb-0" style="color:var(--muted);font-size:.875rem;line-height:1.65;">Submit support tickets in seconds with title, description, and optional screenshots.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="feature-card d2 h-100">
                        <div class="feature-icon" style="background:rgba(56,200,232,.12);">📡</div>
                        <h5 class="fw-bold mb-2" style="font-family:'Syne',sans-serif;font-size:1rem;">Live Status Tracking</h5>
                        <p class="mb-0" style="color:var(--muted);font-size:.875rem;line-height:1.65;">Watch your ticket move from Open → In Progress → Closed with live badge updates.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="feature-card d3 h-100">
                        <div class="feature-icon" style="background:rgba(34,201,138,.12);">🛡️</div>
                        <h5 class="fw-bold mb-2" style="font-family:'Syne',sans-serif;font-size:1rem;">Admin Control</h5>
                        <p class="mb-0" style="color:var(--muted);font-size:.875rem;line-height:1.65;">Admins get a full panel to review all tickets, change statuses, and manage users.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- CTA Banner (logged out only) -->
        <section class="container pb-5">
            <div class="cta-banner">
                <h2 class="fw-bold mb-2" style="font-family:'Syne',sans-serif;font-size:1.8rem;letter-spacing:-.02em;">Ready to get started?</h2>
                <p class="mb-4" style="color:var(--muted);font-size:.95rem;">Join and start managing your support tickets today.</p>
                <div class="d-flex justify-content-center gap-3 flex-wrap">
                    <a href="/register" class="btn-hero-primary">Create Free Account</a>
                    <a href="/login" class="btn-hero-secondary">Sign In</a>
                </div>
            </div>
        </section>

    </main>

    <!-- ── Footer ── -->
    <footer class="site-footer container py-4 d-flex flex-wrap align-items-center justify-content-between gap-3" style="position:relative;z-index:1;">
        <div class="d-flex align-items-center gap-2">
            <div class="brand-icon" style="width:28px;height:28px;border-radius:8px;">
                <svg width="14" height="14" fill="white" viewBox="0 0 24 24"><path d="M9 3H5a2 2 0 00-2 2v4a2 2 0 002 2h4a2 2 0 002-2V5a2 2 0 00-2-2zm0 12H5a2 2 0 00-2 2v4a2 2 0 002 2h4a2 2 0 002-2v-4a2 2 0 00-2-2zm10-12h-4a2 2 0 00-2 2v4a2 2 0 002 2h4a2 2 0 002-2V5a2 2 0 00-2-2zm0 12h-4a2 2 0 00-2 2v4a2 2 0 002 2h4a2 2 0 002-2v-4a2 2 0 00-2-2z"/></svg>
            </div>
            <span class="fw-bold" style="font-family:'Syne',sans-serif;font-size:.875rem;">SupportDesk</span>
        </div>
        <span style="color:var(--muted);font-size:.8rem;">© Developed by Avilash Saha | 2025. All rights reserved.</span>
    </footer>

</body>
</html>
