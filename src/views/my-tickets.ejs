<!DOCTYPE html>
<html>
<head>
    <title>My Tickets</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

    <body class="bg-light">
        <div class="container mt-5">
            <h3>My Tickets</h3>
            <a href="/create-ticket" class="btn btn-success mb-3">Create Ticket</a>

            <table class="table table-bordered">
                <tr>
                    <th class="text-center">Title</th>
                    <th class="text-center">Status</th>
                    <th class="text-center">File</th>
                    <th class="text-center">Action</th>
                </tr>

                <% tickets.forEach(ticket => { %>
                    <tr>
                        <td class="text-center"><%= ticket.title %></td>
                        <td class="text-center"><%= ticket.status %></td>
                        <td class="text-center">
                            <% if(ticket.file_path) { %>
                                <img src="/uploads/<%= ticket.file_path %>" alt="ticket image" style="width:auto; height:80px; object-fit:cover; border-radius:5px; cursor:pointer; transition:0.3s;"
                                    onclick="window.open(this.src)" onmouseover="this.style.transform='scale(1.1)'" onmouseout="this.style.transform='scale(1)'">
                            <% } else { %>
                                No File
                            <% } %>
                        </td>
                        <td class="text-center">
                            <a href="/edit-ticket/<%= ticket.id %>" class="btn btn-sm btn-warning">Edit</a>
                        </td>
                    </tr>
                <% }) %>
            </table>
        </div>
    </body>
</html>