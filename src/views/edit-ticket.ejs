<!DOCTYPE html>
<html>
<head>
    <title>Edit Ticket</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

    <body class="bg-light">
        <div class="container mt-5" style="max-width:600px">
            <h3>Edit Ticket</h3>

            <form action="/edit-ticket/<%= ticket.id %>" method="POST" enctype="multipart/form-data">
                <div class="mb-3">
                    <label>Title</label>
                    <input type="text" name="title" value="<%= ticket.title %>" class="form-control" required>
                </div>

                <div class="mb-3">
                    <label>Description</label>
                    <textarea name="description" class="form-control" required>
                        <%= ticket.description %>
                    </textarea>
                </div>

                <div class="mb-3">
                    <label>Current File</label><br>

                    <% if(ticket.file_path) { %>
                        <img src="/uploads/<%= ticket.file_path %>" width="100">
                    <% } else { %>
                        No file
                    <% } %>
                </div>

                <div class="mb-3">
                    <label>Change File</label>
                    <input type="file" name="file" class="form-control">
                </div>

                <button class="btn btn-success">Update Ticket</button>
            </form>
        </div>
    </body>
</html>