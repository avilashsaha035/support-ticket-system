<!DOCTYPE html>
<html lang="en">
<head>
    <title>Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

    <!-- Header -->
    <header class="site-header px-4 px-md-5 py-3 d-flex align-items-center justify-content-between">
        <div class="d-flex align-items-center gap-3">
            <div class="brand-icon">
                <svg width="18" height="18" fill="white" viewBox="0 0 24 24"><path d="M9 3H5a2 2 0 00-2 2v4a2 2 0 002 2h4a2 2 0 002-2V5a2 2 0 00-2-2zm0 12H5a2 2 0 00-2 2v4a2 2 0 002 2h4a2 2 0 002-2v-4a2 2 0 00-2-2zm10-12h-4a2 2 0 00-2 2v4a2 2 0 002 2h4a2 2 0 002-2V5a2 2 0 00-2-2zm0 12h-4a2 2 0 00-2 2v4a2 2 0 002 2h4a2 2 0 002-2v-4a2 2 0 00-2-2z"/></svg>
            </div>
            <div>
                <div class="fw-bold" style="font-family:'Syne',sans-serif; font-size:1rem; letter-spacing:-.01em; line-height:1;">Support Portal</div>
                <div style="font-size:.7rem; color:var(--muted); text-transform:uppercase; letter-spacing:.08em;">Dashboard</div>
            </div>
        </div>
        <form action="/logout" method="POST">
            <button class="btn btn-outline-ghost px-3 py-2 d-flex align-items-center gap-2">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4M16 17l5-5-5-5M21 12H9"/></svg>
                Logout
            </button>
        </form>
    </header>

    <!-- Main -->
    <main class="container py-5" style="max-width:900px; position:relative; z-index:1;">

        <!-- Welcome Banner -->
        <div class="welcome-banner p-4 mb-5" style="animation: fadeUp .4s ease both;">
            <div class="d-flex align-items-center gap-3">
                <div style="font-size:2rem; line-height:1;">👋</div>
                <div>
                    <h2 class="fw-bold mb-1" style="font-family:'Syne',sans-serif; font-size:1.35rem; letter-spacing:-.02em;">Welcome back!</h2>
                    <p class="mb-0" style="color:var(--muted); font-size:.875rem;">Manage your support tickets from here.</p>
                </div>
            </div>
        </div>

        <!-- Action Cards -->
        <div class="row g-4">
            <div class="col-md-6">
                <div class="dash-card p-4 h-100">
                    <div class="action-icon mb-3" style="background:rgba(91,110,245,.12);">🎫</div>
                    <h5 class="fw-bold mb-1" style="font-family:'Syne',sans-serif;">Create Ticket</h5>
                    <p class="mb-4" style="color:var(--muted); font-size:.875rem;">Submit a new support request and track its progress.</p>
                    <a href="/create-ticket" class="btn btn-accent text-white px-4 py-2">New Ticket</a>
                </div>
            </div>
            <div class="col-md-6">
                <div class="dash-card delay-1 p-4 h-100">
                    <div class="action-icon mb-3" style="background:rgba(34,201,138,.12);">📋</div>
                    <h5 class="fw-bold mb-1" style="font-family:'Syne',sans-serif;">My Tickets</h5>
                    <p class="mb-4" style="color:var(--muted); font-size:.875rem;">View and manage all your previously submitted tickets.</p>
                    <a href="/my-tickets" class="btn text-white px-4 py-2" style="background:#22c98a; border:none; border-radius:10px; font-weight:600; font-size:.875rem;">View Tickets</a>
                </div>
            </div>
        </div>

    </main>

</body>
</html>
